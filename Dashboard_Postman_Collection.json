{
  "info": {
    "name": "ZKTeco Attendance Management System",
    "description": "Complete API collection for ZKTeco Attendance Management System with secure user authentication, device management, user management, and attendance reporting. Default admin credentials: username: 'admin', password: 'admin123'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "description": "Login and authentication endpoints",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response.token);",
                  "    console.log('JWT Token saved:', response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Device Management",
      "description": "Register and manage ZKTeco devices",
      "item": [
        {
          "name": "Create New Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/devices",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"ZK-001\",\n  \"name\": \"Main Office K60\",\n  \"ipAddress\": \"192.168.1.100\",\n  \"location\": \"Office Building - Floor 1\"\n}"
            }
          }
        },
        {
          "name": "Get All Devices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/devices?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Device by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/devices/{{deviceId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices", "{{deviceId}}"]
            }
          }
        },
        {
          "name": "Get Device Statistics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/devices/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices", "stats"]
            }
          }
        },
        {
          "name": "Update Device",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/devices/{{deviceId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices", "{{deviceId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Office K60 Updated\",\n  \"ipAddress\": \"192.168.1.101\",\n  \"location\": \"Office Building - Floor 2\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete Device",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/devices/{{deviceId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices", "{{deviceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "User Management",
      "description": "Manage employee identities and device assignments",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users"]
            }
          }
        },
        {
          "name": "Create New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceUserId\": \"1\",\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"role\": \"EMPLOYEE\",\n  \"departmentId\": \"{{departmentId}}\",\n  \"designationId\": \"{{designationId}}\"\n}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{userId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john123\",\n  \"name\": \"John Doe Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"password\": \"securePassword123\",\n  \"departmentId\": \"{{departmentId}}\",\n  \"designationId\": \"{{designationId}}\"\n}"
            }
          }
        },
        {
          "name": "Assign User to Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{userId}}/devices",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{userId}}", "devices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"{{deviceId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Attendance Management",
      "description": "Attendance data collection and reporting",
      "item": [
        {
          "name": "Check In (Device Webhook)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/check-in",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "check-in"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceUserId\": \"1\",\n  \"timestamp\": \"2026-04-08T09:00:00.000Z\",\n  \"deviceId\": \"ZK-001\"\n}"
            }
          }
        },
        {
          "name": "Check Out (Device Webhook)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/check-out",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "check-out"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceUserId\": \"1\",\n  \"timestamp\": \"2026-04-08T17:00:00.000Z\",\n  \"deviceId\": \"ZK-001\"\n}"
            }
          }
        },
        {
          "name": "Get User Check-in/Check-out",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/user-checkinout?userId={{userId}}&startDate=2026-04-01&endDate=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "user-checkinout"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                },
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-30"
                }
              ]
            }
          }
        },
        {
          "name": "Get Attendance Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/summary?startDate=2026-04-01&endDate=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "summary"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-30"
                }
              ]
            }
          }
        },
        {
          "name": "Get Attendance History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/history?page=1&limit=10&startDate=2026-04-01&endDate=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "history"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-30"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Attendance Sessions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/sessions?page=1&limit=10&startDate=2026-04-01&endDate=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "sessions"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-30"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Users Attendance (Report)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/all-users-attendance?startDate=2026-04-01&endDate=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "all-users-attendance"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-30"
                }
              ]
            }
          }
        },
        {
          "name": "Get Cron Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/cron-status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "cron-status"]
            }
          }
        },
        {
          "name": "Get Attendance Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/attendance/logs?source=all&limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "attendance", "logs"],
              "query": [
                {
                  "key": "source",
                  "value": "all",
                  "description": "Filter by source: all, cron, device"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
